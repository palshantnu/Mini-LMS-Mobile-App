    "react-native-webview": "13.12.5",
    "react-native-worklets": "file:./stubs/react-native-worklets",
    "tailwindcss": "3.4.14",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/axios-mock-adapter": "^1.10.3",
